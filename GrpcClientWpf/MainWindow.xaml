<Window x:Class="GrpcClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Junkyard Client" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Login area -->
        <Label x:Name="login_label" Grid.Row="0" Grid.Column="0" Content="Not logged in" Margin="0,0,0,10"/>
        <TextBox x:Name="username_txt" Grid.Row="1" Grid.Column="0" Width="100" Text="username" Margin="0,0,0,5"/>
        <TextBox x:Name="password_txt" Grid.Row="2" Grid.Column="0" Width="100" Text="password" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,5,0,5">
            <Button x:Name="login_button" Content="Login" Width="60" Margin="0,0,5,0" Click="login_button_Click"/>
            <Button x:Name="logout_button" Content="Logout" Width="60" Click="logout_button_Click"/>
        </StackPanel>

        <!-- CRUD + queries buttons -->
        <StackPanel Grid.Row="1" Grid.Column="1" Grid.RowSpan="3" Orientation="Vertical" Margin="10,0,0,0">
            <Button x:Name="read_button" Content="read" Width="75" Margin="0,0,0,5" Click="read_button_Click"/>
            <Button x:Name="query1_button" Content="query 1" Width="75" Margin="0,0,0,5" Click="query1_button_Click"/>
            <Button x:Name="query2_button" Content="query 2" Width="75" Margin="0,0,0,5" Click="query2_button_Click"/>
            <Button x:Name="query3_button" Content="query 3" Width="75" Margin="0,0,0,5" Click="query3_button_Click"/>
        </StackPanel>

        <!-- ListBox + query3 input -->
        <StackPanel Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" Orientation="Vertical">
            <ListBox x:Name="listBox1" Height="120" Margin="0,0,0,5"/>
            <TextBox x:Name="query3_txt" Width="100" Text="number"/>
        </StackPanel>

        <!-- CRUD input fields -->
        <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Vertical" Margin="0,10,0,0">
            <TextBox x:Name="id_txt" Width="100" Text="id" Margin="0,0,0,5"/>
            <TextBox x:Name="district_txt" Width="100" Text="district" Margin="0,0,0,5"/>
            <TextBox x:Name="address_txt" Width="100" Text="address" Margin="0,0,0,5"/>
            <ComboBox x:Name="waste_box" Width="100" Margin="0,0,0,5" Text="waste">
                <ComboBoxItem Content="biodegradable"/>
                <ComboBoxItem Content="electrical"/>
                <ComboBoxItem Content="wood"/>
                <ComboBoxItem Content="metal"/>
                <ComboBoxItem Content="plastic"/>
                <ComboBoxItem Content="glass"/>
            </ComboBox>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Button x:Name="create_button" Content="create" Width="60" Margin="0,0,5,0" Click="create_button_Click"/>
                <Button x:Name="update_button" Content="update" Width="60" Margin="0,0,5,0" Click="update_Click"/>
                <Button x:Name="delete_button" Content="delete" Width="60" Click="delete_button_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Status label -->
        <Label x:Name="status_label" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0"/>
    </Grid>
</Window>
